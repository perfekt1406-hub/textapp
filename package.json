{
  "name": "textapp",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "setup": "npm install && npm run build",
    "dev": "node scripts/dev.mjs",
    "build": "npm run build -w @textapp/core && npm run build -w @textapp/signaling && npm run build -w @textapp/cli && npm run build -w @textapp/web",
    "test": "npm run test --workspaces --if-present",
    "lint": "eslint .",
    "cli": "npm run start -w @textapp/cli",
    "web": "npm run dev -w @textapp/web",
    "link-cli": "npm run build -w @textapp/cli && npm link -w @textapp/cli",
    "signaling": "npm run start -w @textapp/signaling",
    "dev:signaling": "npm run dev -w @textapp/signaling"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.16.0",
    "globals": "^15.13.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "tsx": "^4.19.2",
    "typescript-eslint": "^8.18.0"
  },
  "engines": {
    "node": ">=20"
  }
}
